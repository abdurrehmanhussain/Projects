{
  "name": "toolshop-playwright-suite",
  "version": "1.0.0",
  "description": "Playwright + TypeScript automation for Practice Software Testing (Toolshop)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test --project=chromium-noauth tests/auth/login.spec.ts",
    "test:products": "playwright test --project=chromium tests/products/",
    "test:cart": "playwright test --project=chromium tests/cart/",
    "test:checkout": "playwright test --project=chromium tests/checkout/",
    "test:e2e": "playwright test --project=chromium tests/e2e/",
    "test:negative": "playwright test --project=negative",
    "test:featured": "playwright test --project=chromium tests/e2e/multi-item-checkout.spec.ts",
    "test:smoke": "playwright test --project=smoke",
    "report": "playwright show-report reports/html",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": ["playwright", "typescript", "pom", "automation", "e2e"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
